datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  TOLL
  OTHER
}

model User {
  id                Int            @id @default(autoincrement())
  name              String
  email             String         @unique
  password          String
  role              Role           @default(DISPATCHER)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  loggedMaintenances Maintenance[]
  loggedActivities  ActivityLog[]
}

model Vehicle {
  id                 Int               @id @default(autoincrement())
  registrationNumber String            @unique
  model              String
  type               String
  capacityKg         Int
  odometer           Int               @default(0)
  acquisitionCost    Decimal           @db.Decimal(12, 2)
  region             String
  status             VehicleStatus     @default(AVAILABLE)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  trips              Trip[]
  maintenances       Maintenance[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([status])
  @@index([region])
}

model Driver {
  id              Int          @id @default(autoincrement())
  name            String
  licenseNumber   String       @unique
  licenseCategory String
  licenseExpiry   DateTime
  phone           String
  safetyScore     Decimal      @default(5.00) @db.Decimal(3, 2)
  status          DriverStatus @default(AVAILABLE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  trips           Trip[]

  @@index([status])
}

model Trip {
  id              Int          @id @default(autoincrement())
  trackingNumber  String       @unique
  vehicleId       Int
  driverId        Int
  cargoWeightKg   Int
  plannedDistance Decimal      @db.Decimal(8, 2)
  actualDistance  Decimal?     @db.Decimal(8, 2)
  revenue         Decimal      @db.Decimal(12, 2)
  startLocation   String
  endLocation     String
  status          TripStatus   @default(DRAFT)
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id])
  driver          Driver       @relation(fields: [driverId], references: [id])
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model Maintenance {
  id          Int               @id @default(autoincrement())
  vehicleId   Int
  description String
  cost        Decimal           @db.Decimal(12, 2)
  startDate   DateTime          @default(now())
  endDate     DateTime?
  status      MaintenanceStatus @default(OPEN)
  loggedById  Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
  loggedBy    User              @relation(fields: [loggedById], references: [id])

  @@index([vehicleId])
  @@index([status])
}

model FuelLog {
  id           Int      @id @default(autoincrement())
  vehicleId    Int
  tripId       Int?
  amountLiters Decimal  @db.Decimal(8, 2)
  cost         Decimal  @db.Decimal(10, 2)
  odometer     Int
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  trip         Trip?    @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
}

model Expense {
  id          Int             @id @default(autoincrement())
  vehicleId   Int?
  tripId      Int?
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  description String
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  vehicle     Vehicle?        @relation(fields: [vehicleId], references: [id])
  trip        Trip?           @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
  @@index([date])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  entityType String
  entityId   Int?
  message    String
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}
